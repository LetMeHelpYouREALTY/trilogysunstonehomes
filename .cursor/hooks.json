{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/prevent-destructive-shell.ps1",
        "failClosed": false
      }
    ],
    "subagentStart": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/review-subagent.ps1",
        "failClosed": false
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/review-mcp.ps1",
        "failClosed": false
      }
    ]
  }
}
