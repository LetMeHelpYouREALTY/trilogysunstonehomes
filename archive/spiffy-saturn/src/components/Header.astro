---
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/neighborhoods/trilogy-sunstone', label: 'Trilogy Sunstone' },
	{ href: '/neighborhoods', label: 'Neighborhoods' },
	{ href: '/buyers-guide', label: "Buyer's Guide" },
	{ href: '/faq', label: 'FAQ' },
	{ href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-white shadow-md transition-all duration-300">
	<nav class="container mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-4" aria-label="Main navigation">
		<a href="/" class="flex flex-col">
			<span class="text-lg md:text-xl font-bold text-slate-900 hover:text-blue-600 transition-colors leading-tight">
				Trilogy Sunstone <span class="text-blue-600">Homes</span>
			</span>
			<span class="text-xs text-slate-500 hidden sm:block">Las Vegas 55+ Community</span>
		</a>
		<ul class="flex flex-wrap items-center gap-5">
			{navLinks.map((link) => (
				<li>
					<a
						href={link.href}
						class="text-slate-700 hover:text-blue-600 font-medium transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 rounded-md px-2 py-1"
					>
						{link.label}
					</a>
				</li>
			))}
			<li>
				<a
					href="tel:+17025001942"
					class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md h-9 px-4 transition-colors"
				>
					Call (702) 500-1942
				</a>
			</li>
		</ul>
	</nav>
</header>
