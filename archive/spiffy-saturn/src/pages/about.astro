---
import MainLayout from '../layouts/main.astro';
---

<MainLayout
	content={{
		title: 'About Trilogy Sunstone | Las Vegas 55+ Community',
		description:
			'Learn about Trilogy Sunstone, Las Vegas\' premier 55+ active lifestyle community. New homes, amenities, and a vibrant neighborhood in Southern Nevada.',
		canonicalURL: 'https://www.trilogysunstonehomes.com/about/',
	}}
>
	<main class="min-h-screen flex flex-col">
		<section class="relative flex flex-col items-center justify-center py-20 px-4 bg-gradient-to-r from-blue-600 to-blue-700 text-white">
			<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-center">About Trilogy Sunstone</h1>
			<p class="text-lg md:text-xl max-w-2xl text-center text-white/90">
				Las Vegas' premier 55+ active lifestyle community—where new homes, amenities, and a vibrant neighborhood come together.
			</p>
		</section>

		<section class="py-16 md:py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6">Our Community</h2>
					<p class="text-slate-700 leading-relaxed mb-4">
						<a href="/neighborhoods/trilogy-sunstone" class="text-blue-600 hover:text-blue-700 font-medium">Trilogy Sunstone</a> offers an active adult lifestyle in one of Las Vegas' most sought-after areas. Residents enjoy a close-knit community, thoughtfully designed new homes, and amenities built for an engaged, healthy life.
					</p>
					<p class="text-slate-700 leading-relaxed">
						Whether you're downsizing, relocating, or looking for your next chapter, we're here to help you <a href="/" class="text-blue-600 hover:text-blue-700 font-medium">find the right home</a> and navigate the Trilogy Sunstone market with our <a href="/buyers-guide" class="text-blue-600 hover:text-blue-700 font-medium">buyer's guide</a> and personalized support.
					</p>
				</div>
			</div>
		</section>

		<section class="py-16 md:py-20 bg-slate-50">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-8">Why Trilogy Sunstone</h2>
					<ul class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
						<li class="bg-white rounded-lg p-6 shadow">
							<h3 class="font-semibold text-blue-600 mb-2">55+ Active Lifestyle</h3>
							<p class="text-slate-600 text-sm">Community designed for active adults with amenities and events that support your lifestyle.</p>
						</li>
						<li class="bg-white rounded-lg p-6 shadow">
							<h3 class="font-semibold text-blue-600 mb-2">New Construction</h3>
							<p class="text-slate-600 text-sm">Discover <a href="/" class="text-blue-600 hover:text-blue-700 font-medium">new homes</a> built for comfort, accessibility, and modern living.</p>
						</li>
						<li class="bg-white rounded-lg p-6 shadow">
							<h3 class="font-semibold text-blue-600 mb-2">Las Vegas Location</h3>
							<p class="text-slate-600 text-sm">Enjoy Southern Nevada's climate, entertainment, and healthcare while living in a dedicated community.</p>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<section class="py-16 md:py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">Ready to Learn More?</h2>
					<p class="text-lg text-slate-700 mb-6">Explore <a href="/" class="text-blue-600 hover:text-blue-700 font-medium">Trilogy Sunstone listings</a>, read our <a href="/faq" class="text-blue-600 hover:text-blue-700 font-medium">FAQ</a>, or get in touch for personalized help.</p>
					<div class="flex flex-wrap gap-4 justify-center">
						<a href="/" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-md shadow transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">View Listings</a>
						<a href="/neighborhoods/trilogy-sunstone" class="inline-flex items-center justify-center border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 font-semibold px-6 py-3 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">Community Details</a>
						<a href="/contact" class="inline-flex items-center justify-center border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 font-semibold px-6 py-3 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">Contact Us</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</MainLayout>
