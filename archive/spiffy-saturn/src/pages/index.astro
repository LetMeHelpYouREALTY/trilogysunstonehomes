---
import '../styles/global.css';
import MainLayout from '../layouts/main.astro';

const testimonialReviews = [
	{
		author: { '@type': 'Person', name: 'Linda S.' },
		reviewBody: 'The process was so easy and the community is amazing!',
		reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
	},
	{
		author: { '@type': 'Person', name: 'Mark L.' },
		reviewBody: 'I found my perfect home and made new friends right away.',
		reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
	},
];

const localBusinessWithReviewsSchema = {
	'@context': 'https://schema.org',
	'@type': 'RealEstateAgent',
	name: 'Trilogy Sunstone Homes',
	url: 'https://www.trilogysunstonehomes.com',
	description: 'Real estate and homes at Trilogy Sunstone, Las Vegas 55+ active adult community.',
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: '5',
		bestRating: '5',
		reviewCount: '2',
	},
	review: testimonialReviews.map((r) => ({
		'@type': 'Review',
		author: r.author,
		reviewBody: r.reviewBody,
		reviewRating: r.reviewRating,
	})),
};
---

<MainLayout
	content={{
		title: 'Trilogy Sunstone Homes for Sale | Las Vegas 55+ Community',
		description:
			"Trilogy Sunstone Las Vegas homes for sale. Find your dream home in the premier 55+ active lifestyle community. Listings, price info, and community reviews.",
		canonicalURL: 'https://www.trilogysunstonehomes.com/',
	}}
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(localBusinessWithReviewsSchema)} />
		<meta name="generator" content={Astro.generator} />
		<!-- RealScout Widget Script - styling in global.css -->
		<script src="https://em.realscout.com/widgets/realscout-web-components.umd.js" type="module"></script>
	</Fragment>
	<main class="min-h-screen flex flex-col">
			<!-- Hero Section -->
			<section class="relative flex flex-col items-center justify-center min-h-[60vh] bg-gradient-to-r from-blue-600 to-blue-700 text-white">
				<h1 class="text-3xl md:text-4xl lg:text-6xl font-bold mb-6 leading-tight text-center">Find Your Dream Home at Trilogy Sunstone</h1>
				<p class="text-lg md:text-xl text-white/90 mb-8 max-w-2xl text-center">Las Vegas' premier 55+ active lifestyle community. Discover new homes, amenities, and a vibrant neighborhood.</p>
				<a href="/contact" class="inline-flex items-center justify-center bg-white text-blue-600 font-semibold px-8 py-4 rounded-md shadow hover:bg-blue-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-600">Get Started</a>
			</section>
			<!-- Pain Point Section -->
			<section class="py-16 md:py-20 bg-white">
				<div class="container mx-auto px-4">
					<div class="max-w-4xl mx-auto flex items-start justify-center gap-3 text-center sm:text-left">
						<div>
							<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">Tired of searching endless listings?</h2>
							<p class="text-lg text-slate-700">We simplify your home search with <a href="/" class="text-blue-600 hover:text-blue-700 font-medium">curated Trilogy Sunstone listings</a>, expert guidance, and exclusive <a href="/neighborhoods/trilogy-sunstone" class="text-blue-600 hover:text-blue-700 font-medium">community insights</a>.</p>
						</div>
						<span class="shrink-0 w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center" aria-hidden="true" title="Info">
							<svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>
						</span>
					</div>
				</div>
			</section>
			<!-- Solution Section -->
			<section class="py-16 md:py-20 bg-slate-50">
				<div class="container mx-auto px-4">
					<div class="max-w-4xl mx-auto text-center">
						<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">A Better Way to Buy</h2>
						<ul class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8" aria-label="Benefits">
							<li class="bg-white rounded-lg p-6 shadow text-slate-900 font-medium">Personalized Home Matches</li>
							<li class="bg-white rounded-lg p-6 shadow text-slate-900 font-medium"><a href="/neighborhoods/trilogy-sunstone" class="text-blue-600 hover:text-blue-700">Neighborhood &amp; Amenity Insights</a></li>
							<li class="bg-white rounded-lg p-6 shadow text-slate-900 font-medium"><a href="/buyers-guide" class="text-blue-600 hover:text-blue-700">Guided Buyer Journey</a></li>
						</ul>
					</div>
				</div>
			</section>
			<!-- Social Proof Section -->
			<section class="py-16 md:py-20 bg-white">
				<div class="container mx-auto px-4">
					<div class="max-w-4xl mx-auto text-center">
						<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">What Buyers Are Saying</h2>
						<div class="flex flex-col md:flex-row gap-8 justify-center mt-8">
							<blockquote class="bg-slate-50 rounded-lg p-6 shadow max-w-sm mx-auto text-slate-700">“The process was so easy and the community is amazing!”<br/><span class="block mt-2 font-semibold text-blue-600">— Linda S.</span></blockquote>
							<blockquote class="bg-slate-50 rounded-lg p-6 shadow max-w-sm mx-auto text-slate-700">“I found my perfect home and made new friends right away.”<br/><span class="block mt-2 font-semibold text-blue-600">— Mark L.</span></blockquote>
						</div>
					</div>
				</div>
			</section>
			<!-- Listings Section -->
			<section class="py-16 md:py-20 bg-slate-50 min-h-[480px] flex flex-col items-center justify-center relative z-[1]">
				<div class="container mx-auto px-4 w-full max-w-5xl">
					<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4 text-center">Trilogy Sunstone Homes for Sale</h2>
					<p class="text-center text-slate-600 mb-8">Explore current listings and home values in the <a href="/neighborhoods/trilogy-sunstone" class="text-blue-600 hover:text-blue-700 font-medium">Trilogy Sunstone community</a>.</p>
					<div class="w-full min-h-[400px] flex items-center justify-center rounded-lg bg-white shadow border border-slate-200" id="widget-container">
						<realscout-office-listings agent-encoded-id="QWdlbnQtMjI1MDUw" sort-order="NEWEST" listing-status="For Sale" property-types="SFR,MF" price-min="500000" price-max="700000"></realscout-office-listings>
					</div>
				</div>
			</section>
			<!-- Objection Handling Section -->
			<section class="py-16 md:py-20 bg-white">
				<div class="container mx-auto px-4">
					<div class="max-w-4xl mx-auto text-center">
						<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">Have Questions or Concerns?</h2>
						<p class="text-lg text-slate-700 mb-6">Our team is here to help you every step of the way. No pressure, just guidance. See our <a href="/faq" class="text-blue-600 hover:text-blue-700 font-medium">FAQ</a> for common questions, or reach out anytime.</p>
						<a href="/contact" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-md shadow transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">Ask a Question</a>
					</div>
				</div>
			</section>
			<!-- Clear CTA Section -->
			<section class="py-16 md:py-20 bg-blue-600 text-white">
				<div class="container mx-auto px-4 text-center">
					<h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Start Your Journey?</h2>
					<p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">Get your free <a href="/buyers-guide" class="text-white font-semibold underline underline-offset-2 hover:no-underline">buyer's guide</a> and <a href="/neighborhoods/trilogy-sunstone" class="text-white font-semibold underline underline-offset-2 hover:no-underline">community insights</a>.</p>
					<a href="/buyers-guide" class="inline-flex items-center justify-center bg-white text-blue-600 font-bold px-8 py-4 rounded-md shadow hover:bg-blue-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-600">Get Your Free Guide</a>
				</div>
			</section>
	</main>
</MainLayout>
