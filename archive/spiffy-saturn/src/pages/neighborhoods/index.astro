---
import MainLayout from '../../layouts/main.astro';
---

<MainLayout
	content={{
		title: 'Neighborhoods & Communities | Trilogy Sunstone Homes',
		description:
			'Explore Trilogy Sunstone and nearby Las Vegas 55+ and active adult communities. Find the right neighborhood for your next home.',
		canonicalURL: 'https://www.trilogysunstonehomes.com/neighborhoods/',
	}}
>
	<main class="min-h-screen flex flex-col">
		<section class="relative flex flex-col items-center justify-center py-20 px-4 bg-gradient-to-r from-blue-600 to-blue-700 text-white">
			<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-center">Neighborhoods We Serve</h1>
			<p class="text-lg md:text-xl max-w-2xl text-center text-white/90">
				Trilogy Sunstone and surrounding Las Vegas area communities.
			</p>
		</section>

		<section class="py-16 md:py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-2xl font-bold text-slate-900 mb-8">Featured Community</h2>
					<div class="rounded-lg border border-slate-200 bg-slate-50 p-6 md:p-8">
						<h3 class="text-xl font-bold text-blue-600 mb-2"><a href="/neighborhoods/trilogy-sunstone" class="text-blue-600 hover:text-blue-800">Trilogy Sunstone</a></h3>
						<p class="text-slate-700 mb-4">
							Las Vegas' premier 55+ active lifestyle community. <a href="/" class="text-blue-600 hover:text-blue-700 font-medium">New homes</a> for sale, resort-style amenities, and a vibrant neighborhood designed for active adults.
						</p>
						<div class="flex flex-wrap gap-3">
							<a href="/neighborhoods/trilogy-sunstone" class="inline-flex items-center justify-center px-6 py-3 rounded-md font-semibold border border-slate-300 text-slate-700 hover:bg-white transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">Learn About the Community</a>
							<a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-md font-semibold bg-blue-600 text-white hover:bg-blue-700 transition-colors shadow focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">View Trilogy Sunstone Listings</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="py-16 md:py-20 bg-slate-50">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto">
					<h2 class="text-2xl font-bold text-slate-900 mb-6">Nearby Las Vegas Areas</h2>
					<p class="text-slate-700 mb-8">
						We also serve buyers and sellers in surrounding Southern Nevada communities. Ask us about Summerlin, Henderson, Green Valley, and more.
					</p>
					<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
						<li class="bg-white rounded-lg p-4 shadow"><span class="font-medium text-slate-900">Summerlin</span><p class="text-sm text-slate-600 mt-1">Master-planned community west of Las Vegas.</p></li>
						<li class="bg-white rounded-lg p-4 shadow"><span class="font-medium text-slate-900">Henderson</span><p class="text-sm text-slate-600 mt-1">Family and active adult communities southeast of Las Vegas.</p></li>
						<li class="bg-white rounded-lg p-4 shadow"><span class="font-medium text-slate-900">Green Valley</span><p class="text-sm text-slate-600 mt-1">Henderson area with strong 55+ options.</p></li>
						<li class="bg-white rounded-lg p-4 shadow"><span class="font-medium text-slate-900">North Las Vegas</span><p class="text-sm text-slate-600 mt-1">Growing area with new construction and value.</p></li>
					</ul>
				</div>
			</div>
		</section>

		<section class="py-16 md:py-20 bg-white">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl font-bold text-slate-900 mb-4">Not Sure Where to Start?</h2>
					<p class="text-slate-700 mb-6">Read our <a href="/buyers-guide" class="text-blue-600 hover:text-blue-700 font-medium">buyer's guide</a> or check the <a href="/faq" class="text-blue-600 hover:text-blue-700 font-medium">FAQ</a>.</p>
					<a href="/contact" class="inline-flex items-center justify-center px-6 py-3 rounded-md font-semibold bg-blue-600 text-white hover:bg-blue-700 transition-colors shadow focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">Contact Us</a>
				</div>
			</div>
		</section>
	</main>
</MainLayout>
